  "item": [
    {
      "name": "Global _Get Single User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status code is 200\",()=>{\r",
              "pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Successful GET request\", ()=>{\r",
              "pm.expect(pm.response.code).to.be.oneOf([200,202]);\r",
              "});\r",
              "\r",
              "pm.test(\"status code name has string\",()=> {\r",
              "pm.response.to.have.status(\"OK\");\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "pm.test(\"Test array properites\",()=>{\r",
              "\r",
              "    //courses includes \"C#\"\r",
              "    pm.expect(jsonData.courses).to.include(\"C#\");\r",
              "\r",
              "    //courses includes \"RestAPI\"\r",
              "    pm.expect(jsonData.courses).to.include(\"RestAPI\");\r",
              "\r",
              "    //courses does not include \"python\"\r",
              "    pm.expect(jsonData.courses).to.not.include(\"python\");\r",
              "\r",
              "     // coures array must includes all listed\r",
              "    pm.expect(jsonData.courses).to.include.members([\"C#\", \"RestAPI\"]);\r",
              "    pm.expect(jsonData.courses).to.have.members([\"RestAPI\", \"C#\"]);\r",
              "\r",
              "    //courses length is 2\r",
              "    pm.expect(jsonData.courses.length).to.eql(2);\r",
              "    pm.expect(jsonData.courses).to.have.lengthOf(2);\r",
              "    pm.expect(jsonData.courses).to.have.length(2);\r",
              "\r",
              "});\r",
              "\r",
              "pm.test(\"Validate the fileds in the Response\",()=>{\r",
              "var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.eql(\"3\");\r",
              "    pm.expect(jsonData.name).to.eql(\"Smith\");\r",
              "    pm.expect(jsonData.location).to.eql(\"Canada\");\r",
              "    pm.expect(jsonData.phone).to.eql(\"165498765\");\r",
              "    pm.expect(jsonData.courses[0]).to.eql(\"C#\");\r",
              "    pm.expect(jsonData.courses[1]).to.eql(\"RestAPI\");\r",
              "\r",
              "});\r",
              "\r",
              "var schema = {\r",
              "    \"type\": \"object\",\r",
              "    \"properties\": {\r",
              "        \"id\": {\"type\": \"string\"},\r",
              "        \"name\": {\"type\": \"string\"},\r",
              "        \"location\": {\"type\": \"string\"},\r",
              "        \"phone\": {\"type\": \"string\"},\r",
              "        \"courses\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}}\r",
              "        },\r",
              "        \"required\": [\"id\", \"name\", \"location\", \"phone\", \"courses\"]\r",
              "};\r",
              "\r",
              "pm.test(\"Response matches the JSON Schema\", function () {\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
