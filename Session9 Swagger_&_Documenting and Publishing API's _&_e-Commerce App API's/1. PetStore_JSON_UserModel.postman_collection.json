      "name": "Create User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var randomString = Math.random().toString(36).substring(2, 8);\r",
              "var randomInt = Math.floor(Math.random() * 10000);\r",
              "\r",
              "pm.collectionVariables.set(\"id\",randomInt);\r",
              "pm.collectionVariables.set(\"user_name\",randomString);\r",
              "pm.collectionVariables.set(\"firstName\",randomString);\r",
              "pm.collectionVariables.set(\"lastName\",randomString);\r",
              "pm.collectionVariables.set(\"Gmail\",(randomString+\"@gmail.com\"));\r",
              "pm.collectionVariables.set(\"password\",randomString);\r",
              "pm.collectionVariables.set(\"phone\",randomString);\r",
              "pm.collectionVariables.set(\"userStatus\",randomInt);\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Successful POST request\", () => { \r",
              "pm.expect(pm.response.code).to.be.oneOf([201,200]);\r",
